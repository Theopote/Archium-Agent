# Archium Agent - All-in-One Docker Image
# Python + Node.js runtime for easy deployment

FROM python:3.11-slim

LABEL maintainer="Archium Team"
LABEL description="Archium AI-powered architectural presentation generator"

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    # Node.js 和 npm
    nodejs \
    npm \
    # Git (用于版本信息)
    git \
    # 清理缓存减小镜像体积
    && rm -rf /var/lib/apt/lists/*

# 设置工作目录
WORKDIR /app

# 复制 Python 依赖文件
COPY pyproject.toml poetry.lock ./

# 安装 Poetry 并安装 Python 依赖
RUN pip install --no-cache-dir poetry==1.7.1 \
    && poetry config virtualenvs.create false \
    && poetry install --no-dev --no-interaction --no-ansi

# 复制 Node.js 渲染器依赖文件
COPY archium/infrastructure/renderers/pptxgen/package*.json \
     archium/infrastructure/renderers/pptxgen/

# 安装 Node.js 依赖
RUN cd archium/infrastructure/renderers/pptxgen \
    && npm ci --production \
    && cd /app

# 复制应用代码
COPY . .

# 创建数据目录
RUN mkdir -p data/database data/projects data/uploads

# 暴露 Streamlit 端口
EXPOSE 8501

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import requests; requests.get('http://localhost:8501/_stcore/health')" || exit 1

# 设置环境变量
ENV STREAMLIT_SERVER_PORT=8501
ENV STREAMLIT_SERVER_ADDRESS=0.0.0.0
ENV STREAMLIT_SERVER_HEADLESS=true
ENV STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# 启动命令
CMD ["streamlit", "run", "app.py", "--server.port=8501", "--server.address=0.0.0.0"]

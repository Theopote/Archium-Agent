# Environment
.env
.venv/
venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Node
node_modules/

# Golden case runtime artifacts (manifests saved during pytest)
tests/golden/artifacts/*
!tests/golden/artifacts/README.md
!tests/golden/artifacts/.gitkeep

# PPTX screenshot candidates (human review → approve-baseline; never commit)
tests/golden/visual/composition/**/candidates/

# Smoke test CI artifacts (uploaded by GitHub Actions, not versioned)
tests/smoke/artifacts/*
!tests/smoke/artifacts/README.md
!tests/smoke/artifacts/.gitkeep

# Phase 8 real-project RenderScene deliverable dumps (regenerate via scripts/run_phase8_real_projects.py)
tests/e2e/real_projects/*/outputs/

# Layer 2 sanitized real project files (keep directory structure only)
tests/golden/fixtures/files/**
!tests/golden/fixtures/files/.gitkeep

# Data / runtime (never commit — use CI artifacts or reviewed goldens)
.data/
data/output/
data/outputs/
data/projects/
data/chroma/
data/tmp/
data/database/*.db
data/database/*.db-wal
data/database/*.db-shm
output/
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# Logs
*.log
alerts.log

# IDE
.idea/
.vscode/
*.swp

# Local dev notes — CI screenshot imports (never commit)
.dev-notes/ci-screenshot*
.dev-notes/_ci_candidates_import*
